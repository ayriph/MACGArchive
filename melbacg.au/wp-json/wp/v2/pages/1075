.au\/about\/\"> [...]<\/a>","protected":false},"author":1,"featured_media":1118,"parent":0,"menu_order":0,"comment_status":"open","ping_status":"open","template":"","meta":{"_coblocks_attr":"","_coblocks_dimensions":"","_coblocks_responsive_height":"","_coblocks_accordion_ie_support":"","footnotes":""},"class_list":["post-1075","page","type-page","status-publish","has-post-thumbnail","hentry"],"_links":{"self":[{"href":"https:\/\/melbacg.au\/wp-json\/wp\/v2\/pages\/1075","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/melbacg.au\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/melbacg.au\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/melbacg.au\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/melbacg.au\/wp-json\/wp\/v2\/comments?post=1075"}],"version-history":[{"count":7,"href":"https:\/\/melbacg.au\/wp-json\/wp\/v2\/pages\/1075\/revisions"}],"predecessor-version":[{"id":1529,"href":"https:\/\/melbacg.au\/wp-json\/wp\/v2\/pages\/1075\/revisions\/1529"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/melbacg.au\/wp-json\/wp\/v2\/media\/1118"}],"wp:attachment":[{"href":"https:\/\/melbacg.au\/wp-json\/wp\/v2\/media?parent=1075"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}